<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Profile</title>
    <style>
        body {
            font-family: Arial;
            background: #020617;
            color: #e2e8f0;
            text-align: center;
            padding: 50px;
        }
        .card {
            background: #1e293b;
            padding: 20px;
            border-radius: 10px;
            display: inline-block;
        }
        a {
            display: block;
            margin-top: 10px;
            color: #38bdf8;
        }
    </style>
</head>
<body>

    <div class="card">
        <h1>Profile</h1>

        <p>Welcome, <%= user %> 👋</p>

        <a href="/">Home</a>
    </div>

</body>
</html>